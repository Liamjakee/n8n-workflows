    {
      "id": "p-node-18",
      "name": "Ordenar y Formatear Informe",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1650, 300],
      "parameters": {
        "jsCode": "const staticData = $getWorkflowStaticData('global');\n\nconst qualified = (staticData['qualified_this_run'] || [])\n  .sort((a, b) => b.score - a.score)\n  .slice(0, 5);\n\nconst processed = staticData['factories_processed'] || 0;\nconst rejected = processed - qualified.length;\n\nconst now = new Date();\nconst pad = n => String(n).padStart(2, '0');\nconst dateStr = pad(now.getDate()) + '/' + pad(now.getMonth() + 1) + '/' + now.getFullYear();\n\nlet message;\n\nif (qualified.length === 0) {\n  message = [\n    '\uD83D\uDD0D <b>THE PROSPECTOR</b> \u2014 Semana del ' + dateStr,\n    '\u2705 Escaneo completado \u2014 ninguna nueva f\u00e1brica calificada esta semana',\n    '\uD83D\uDCCA ' + processed + ' candidato' + (processed !== 1 ? 's' : '') + ' analizado' + (processed !== 1 ? 's' : '') + ', ' + rejected + ' rechazado' + (rejected !== 1 ? 's' : ''),\n    '\uD83D\uDCC5 ' + dateStr\n  ].join('\\n');\n} else {\n  const medals = ['\uD83E\uDD47', '\uD83E\uDD48', '\uD83E\uDD49', '4\uFE0F\u20E3', '5\uFE0F\u20E3'];\n  const n = qualified.length;\n\n  const lines = [\n    '\uD83D\uDD0D <b>THE PROSPECTOR</b> \u2014 Semana del ' + dateStr,\n    '<b>' + n + ' nueva' + (n > 1 ? 's' : '') + ' f\u00e1brica' + (n > 1 ? 's' : '') + ' identificada' + (n > 1 ? 's' : '') + '</b>',\n    ''\n  ];\n\n  for (let i = 0; i < qualified.length; i++) {\n    const f = qualified[i];\n    lines.push(medals[i] + ' <b>' + f.factory_name + '</b>' + (f.region ? ' (' + f.region + ')' : '') + ' \u2014 Puntuaci\u00f3n\u00a0: ' + f.score + '/10');\n    if (f.french_summary) lines.push(f.french_summary);\n    if (f.contact_email) lines.push('\uD83D\uDCE7 ' + f.contact_email);\n    if (f.website) lines.push('\uD83C\uDF0D ' + f.website);\n    lines.push('');\n  }\n\n  lines.push('\u27A1\uFE0F Base completa\u00a0: Google Sheets');\n  lines.push('\uD83D\uDCCA ' + processed + ' candidatos analizados en total');\n  lines.push('\uD83D\uDCC5 ' + dateStr);\n\n  message = lines.join('\\n');\n}\n\nconst MAX_CHUNK = 3800;\nconst chunks = [];\nlet remaining = message;\nwhile (remaining.length > 0) {\n  if (remaining.length <= MAX_CHUNK) {\n    chunks.push(remaining);\n    break;\n  }\n  let cut = remaining.lastIndexOf('\\n', MAX_CHUNK);\n  if (cut < 0) cut = MAX_CHUNK;\n  chunks.push(remaining.substring(0, cut));\n  remaining = remaining.substring(cut + 1);\n}\n\nreturn chunks.map((chunk, i) => ({\n  json: {\n    text: chunk,\n    chunk_index: i + 1,\n    total_chunks: chunks.length\n  }\n}));"
      }
