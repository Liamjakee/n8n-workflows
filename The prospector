        "jsCode": "function extractDomain(url) {\n  try {\n    return new URL(url).hostname.replace(/^www\\./, '');\n  } catch(e) {\n    return '';\n  }\n}\n\nfunction cleanBaseUrl(url) {\n  try {\n    const u = new URL(url);\n    return u.protocol + '//' + u.hostname;\n  } catch(e) {\n    return url;\n  }\n}\n\nconst staticData = $getWorkflowStaticData('global');\nconst response = $input.first().json;\nconst sourceItem = $('Dividir Fuentes de B\u00fasqueda').first().json;\n\nconst REJECTION_KEYWORDS = ['showroom', 'punto vendita', 'rivenditore', 'negozio', 'outlet', 'retailer'];\nconst allResults = staticData['discovered_urls'] || [];\nconst seenDomains = new Set(allResults.map(r => r.domain));\n\nlet newItems = [];\n\nif (sourceItem.type === 'serpapi') {\n  const organic = response.organic_results || [];\n  for (const r of organic) {\n    const url = r.link || '';\n    const domain = extractDomain(url);\n    if (!domain || seenDomains.has(domain)) continue;\n    const titleLower = (r.title || '').toLowerCase();\n    const isRetail = REJECTION_KEYWORDS.some(kw => titleLower.includes(kw) || domain.includes(kw));\n    if (isRetail) continue;\n    if (!domain.endsWith('.it') && !domain.endsWith('.eu') && !domain.endsWith('.com')) continue;\n    newItems.push({\n      name: r.title || domain,\n      url: cleanBaseUrl(url),\n      domain: domain,\n      source: sourceItem.label\n    });\n    seenDomains.add(domain);\n  }\n} else {\n  // Scrape HTML: extraer URLs .it con patrón simple\n  const html = response.data || response.body || '';\n  const urlRegex = /https?:\\/\\/(?:www\\.)?[\\w-]+\\.it[\\w/.?=#%-]*/g;\n  const urlMatches = html.match(urlRegex) || [];\n  for (const url of urlMatches) {\n    const domain = extractDomain(url);\n    if (!domain || seenDomains.has(domain)) continue;\n    if (domain.includes('federlegno') || domain.includes('furniture.eu') || domain.includes('google')) continue;\n    newItems.push({\n      name: domain.replace('.it', '').replace(/-/g, ' ').replace(/\\b\\w/g, c => c.toUpperCase()),\n      url: cleanBaseUrl(url),\n      domain: domain,\n      source: sourceItem.label\n    });\n    seenDomains.add(domain);\n  }\n}\n\nstaticData['discovered_urls'] = [...allResults, ...newItems];\n\nreturn [{ json: { added: newItems.length, total: staticData['discovered_urls'].length, source: sourceItem.label } }];"
      }
