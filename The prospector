        "jsCode": "function extractDomain(url) {\n  try {\n    return new URL(url).hostname.replace(/^www\\./, '');\n  } catch(e) {\n    return (url || '').replace(/^https?:\\/\\/(?:www\\.)?/, '').split('/')[0];\n  }\n}\n\nconst staticData = $getWorkflowStaticData('global');\nconst sheetsRows = $input.all();\n\n// Construir conjunto de dominios ya conocidos desde Google Sheets Columna B (Website URL)\nconst knownDomains = new Set();\nfor (const row of sheetsRows) {\n  const url = row.json['Website URL'] || row.json['B'] || row.json.website || '';\n  const domain = extractDomain(url);\n  if (domain) knownDomains.add(domain);\n}\n\n// Excluidos permanentemente: proveedores actuales del cliente + nivel ultra-lujo\nconst EXCLUDED_DOMAINS = new Set([\n  'natuzzi.com', 'nicolettihome.com', 'calia.it', 'maxdivani.it',\n  'estromilano.it', 'innovaimbottiti.it', 'francoferri.it', 'egoitaliano.it',\n  'gorini.it', 'doimosalotti.it', 'divadivani.it',\n  'bebitalia.com', 'poltrona-frau.com', 'cassina.com', 'flexform.it',\n  'minotti.it', 'rolfbenz.de', 'maxalto.it', 'edraonline.com'\n]);\n\nconst discovered = staticData['discovered_urls'] || [];\n\nconst newFactories = discovered.filter(f => {\n  if (!f.domain || !f.url) return false;\n  if (knownDomains.has(f.domain)) return false;\n  if (EXCLUDED_DOMAINS.has(f.domain)) return false;\n  return true;\n});\n\nstaticData['qualified_this_run'] = [];\nstaticData['factories_to_process'] = newFactories.length;\n\nif (newFactories.length === 0) {\n  return [{ json: { _skip: true, name: '__no_new_factories__', url: '', domain: '', source: '' } }];\n}\n\nreturn newFactories.map(f => ({ json: f }));"
