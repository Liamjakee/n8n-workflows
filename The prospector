    {
      "id": "p-node-14",
      "name": "Analizar y Guardar Resultado de Evaluación",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [3650, 780],
      "parameters": {
        "jsCode": "const item = $input.first().json;\nconst factoryData = $('Esperar 15 Segundos').first().json;\nconst staticData = $getWorkflowStaticData('global');\n\nstaticData['factories_processed'] = (staticData['factories_processed'] || 0) + 1;\n\nlet responseContent = '';\n\nif (item.choices && Array.isArray(item.choices) && item.choices.length > 0) {\n  responseContent = (item.choices[0].message && item.choices[0].message.content) ? item.choices[0].message.content : '';\n} else {\n  responseContent = JSON.stringify({\n    factory_name: factoryData.name || factoryData.url,\n    passes_gates: false,\n    gate_failures: ['Error de API Groq: ' + JSON.stringify(item).substring(0, 100)],\n    score: 0,\n    score_breakdown: { catalogue: 0, no_french_distribution: 0, competitor_absence: 0 },\n    product_focus: '',\n    contact_email: '',\n    region: '',\n    french_summary: '',\n    rejection_reason: 'Error de API Groq durante la evaluaci\u00f3n'\n  });\n}\n\n// Eliminar bloques de código markdown antes de analizar\nresponseContent = responseContent\n  .replace(/^```json\\s*/i, '')\n  .replace(/^```\\s*/i, '')\n  .replace(/\\s*```$/i, '')\n  .trim();\n\nlet result;\ntry {\n  result = JSON.parse(responseContent);\n  result.factory_name = result.factory_name || factoryData.name || factoryData.url || 'Desconocido';\n  result.score = Math.max(0, Math.min(10, Number(result.score) || 0));\n  result.passes_gates = Boolean(result.passes_gates);\n  result.gate_failures = Array.isArray(result.gate_failures) ? result.gate_failures : [];\n  result.score_breakdown = result.score_breakdown || { catalogue: 0, no_french_distribution: 0, competitor_absence: 0 };\n  result.contact_email = result.contact_email || '';\n  result.region = result.region || '';\n  result.french_summary = result.french_summary || '';\n  result.rejection_reason = result.rejection_reason || '';\n  result.product_focus = result.product_focus || '';\n} catch(e) {\n  result = {\n    factory_name: factoryData.name || 'Desconocido',\n    passes_gates: false,\n    gate_failures: ['Error de an\u00e1lisis JSON: ' + e.message],\n    score: 0,\n    score_breakdown: { catalogue: 0, no_french_distribution: 0, competitor_absence: 0 },\n    product_focus: '',\n    contact_email: '',\n    region: '',\n    french_summary: '',\n    rejection_reason: 'Error de an\u00e1lisis: ' + responseContent.substring(0, 150)\n  };\n}\n\nresult.website = factoryData.url || '';\nresult.domain = factoryData.domain || '';\nresult.source = factoryData.source || '';\nresult.date_discovered = new Date().toISOString().split('T')[0];\nresult.status = (result.score >= 5 && result.passes_gates) ? 'Calificado' : 'Rechazado';\n\nif (result.score >= 5 && result.passes_gates) {\n  const q = staticData['qualified_this_run'] || [];\n  q.push(result);\n  staticData['qualified_this_run'] = q;\n}\n\nreturn [{ json: result }];"
