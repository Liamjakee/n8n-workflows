        "jsCode": "try {\n  const d = $input.item.json;\n  const factories = d.most_sold || [];\n  const now = new Date();\n  const meses = ['enero','febrero','marzo','abril','mayo','junio','julio','agosto','septiembre','octubre','noviembre','diciembre'];\n  const runDateEs = now.getDate() + ' de ' + meses[now.getMonth()] + ' de ' + now.getFullYear();\n\n  const nf = new Intl.NumberFormat('es-ES', { minimumFractionDigits: 0, maximumFractionDigits: 0 });\n  const fmt = function(val) { return (!val || isNaN(Number(val))) ? '' : nf.format(val) + '\\u00a0€'; };\n\n  let msg = '<b>🛋 Ranking de Sofás Más Vendidos por Fábrica</b>\\n';\n  msg += '📅 <i>' + runDateEs + '</i>\\n\\n';\n\n  if (factories.length === 0) {\n    msg += '⚠️ No se obtuvieron datos esta ejecución.';\n  } else {\n    factories.forEach(function(f, i) {\n      const prods = f.products || [];\n      const top = prods[0];\n      const rank = i + 1;\n\n      let line = rank + '. <b>' + f.factory_name + '</b>';\n\n      if (top && top.name) {\n        const parts = [];\n        parts.push(top.name + (top._is_new_this_week ? ' 🆕' : ''));\n        if (top.materials) parts.push(top.materials);\n        const price = fmt(top.price_eur);\n        if (price) parts.push('💶 ' + price);\n        line += ' — ' + parts.join(' · ');\n      } else {\n        line += ' — <i>Sin datos</i>';\n      }\n\n      msg += line + '\\n';\n    });\n  }\n\n  const maxLen = 3800;\n  const chunks = [];\n  if (msg.length <= maxLen) {\n    chunks.push(msg);\n  } else {\n    const lines = msg.split('\\n');\n    let current = '';\n    for (const line of lines) {\n      if ((current + line + '\\n').length > maxLen) {\n        chunks.push(current);\n        current = line + '\\n';\n      } else {\n        current += line + '\\n';\n      }\n    }\n    if (current) chunks.push(current);\n  }\n\n  return [{ json: { telegram_chunks: chunks } }];\n\n} catch (e) {\n  return [{ json: { telegram_chunks: ['❌ <b>Error al generar el informe:</b> ' + e.message] } }];\n}"
