      "parameters": {
        "jsCode": "try {\n  const resp = $input.item.json;\n\n  // Generic API error handling — works for any OpenAI-compatible response\n  if (resp.error) {\n    return [{ json: {\n      parse_error: true,\n      parse_error_reason: 'API_ERROR',\n      error_message: (resp.error.message || JSON.stringify(resp.error)),\n      products: [], marketIntel: [], socialSignals: [], actions: []\n    } }];\n  }\n\n  const codigoEstado = resp.statusCode || resp.status || null;\n  if (codigoEstado && codigoEstado >= 400) {\n    return [{ json: { parse_error: true, parse_error_reason: 'HTTP_' + codigoEstado, products: [], marketIntel: [], socialSignals: [], actions: [] } }];\n  }\n\n  // Groq / OpenAI format: choices[0].message.content\n  const textoRaw = resp.choices && resp.choices[0] && resp.choices[0].message && resp.choices[0].message.content\n    ? resp.choices[0].message.content\n    : '';\n\n  if (!textoRaw) {\n    return [{ json: { parse_error: true, parse_error_reason: 'CHOICES_ARRAY_MISSING_OR_EMPTY', products: [], marketIntel: [], socialSignals: [], actions: [] } }];\n  }\n\n  // Strip markdown code fences Groq sometimes wraps around JSON output\n  let cleaned = textoRaw.trim();\n  cleaned = cleaned.replace(/^```json\\s*/i, '').replace(/^```\\s*/, '').replace(/```\\s*$/, '').trim();\n\n  let analizado = null;\n  try {\n    analizado = JSON.parse(cleaned);\n  } catch (_) {\n    const coincidencia = cleaned.match(/\\{[\\s\\S]*\\}/);\n    if (coincidencia) {\n      try { analizado = JSON.parse(coincidencia[0]); } catch (_2) { analizado = null; }\n    }\n  }\n\n  if (!analizado || typeof analizado !== 'object') {\n    return [{ json: { parse_error: true, parse_error_reason: 'JSON_NO_INTERPRETABLE', products: [], marketIntel: [], socialSignals: [], actions: [] } }];\n  }\n\n  return [{ json: {\n    ...analizado,\n    products: analizado.products || [],\n    marketIntel: analizado.marketIntel || [],\n    socialSignals: analizado.socialSignals || [],\n    actions: analizado.actions || [],\n    parse_error: false\n  } }];\n} catch (e) {\n  return [{ json: { parse_error: true, parse_error_reason: e.message, products: [], marketIntel: [], socialSignals: [], actions: [] } }];\n}"
      },
