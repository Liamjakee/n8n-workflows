(Object.assign({}, factory, { products: taggedProducts, new_count: newCount }));\n  }\n\n  // Persist — static data is automatically saved by n8n\n  staticData.snapshots = snapshots;\n\n  const byCommercial = processedFactories.slice().sort(function(a, b) { return b.commercial_score - a.commercial_score; });\n  const mostSold = byCommercial.map(function(f, i) { return Object.assign({}, f, { commercial_rank: i + 1 }); });\n  const bySocial = processedFactories.slice().sort(function(a, b) { return b.social_score - a.social_score; });\n  const mostInfluential = bySocial.map(function(f, i) { return Object.assign({}, f, { social_rank: i + 1 }); });\n\n  return [{ json: {\n    factories: processedFactories,\n    most_sold: mostSold,\n    most_influential: mostInfluential,\n    skipped_factories: skippedFactories\n  } }];\n} catch (e) {\n  return [{ json: {\n    factories: [], most_sold: [], most_influential: [],\n    skipped_factories: [], detect_error: e.message\n  } }];\n}"
