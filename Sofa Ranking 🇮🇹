        "jsCode": "try {\n  const data = $input.item.json.data || [];\n  const byFactory = new Map();\n\n  for (const row of data) {\n    const key = row.factory_name || 'DESCONOCIDO';\n    if (!byFactory.has(key)) {\n      byFactory.set(key, { factory_name: key, sources: [], products: [], socialSignals: [], marketIntel: [], actions: [] });\n    }\n    const f = byFactory.get(key);\n    f.sources.push(row);\n    (row.products || []).forEach(function(p) { f.products.push(Object.assign({}, p, { source_type: row.source_type })); });\n    if (row.social && Object.keys(row.social).length > 0) f.socialSignals.push(row.social);\n    if (row.market_intel && Object.keys(row.market_intel).length > 0) f.marketIntel.push(row.market_intel);\n    (row.actionable_insights || []).forEach(function(a) { f.actions.push(a); });\n  }\n\n  const factories = [];\n\n  for (const entry of byFactory.entries()) {\n    const f = entry[1];\n    const allFresh = f.sources.length > 0 && f.sources.every(function(s) { return s.source_type === 'snapshot_cache'; });\n\n    let commercial = 0;\n    let social = 0;\n    let bestsellerCount = 0;\n    let newCount = 0;\n    let reviewScoreSum = 0;\n    let reviewScoreCount = 0;\n    let positiveSentimentHits = 0;\n\n    for (const p of f.products) {\n      if (p.is_bestseller) bestsellerCount += 1;\n      if (p.is_new) newCount += 1;\n    }\n\n    for (const mi of f.marketIntel) {\n      if (typeof mi.review_score === 'number' && mi.review_score > 0) {\n        reviewScoreSum += mi.review_score;\n        reviewScoreCount += 1;\n      }\n      const sentiment = (mi.customer_sentiment || '').toLowerCase();\n      if (sentiment.includes('positivo') || sentiment.includes('positive') || sentiment.includes('buono') || sentiment.includes('good')) {\n        positiveSentimentHits += 1;\n      }\n    }\n\n    const avgReview = reviewScoreCount > 0 ? reviewScoreSum / reviewScoreCount : 0;\n    commercial += Math.min(bestsellerCount * 15, 30);\n    commercial += Math.min(newCount * 5, 15);\n    commercial += avgReview * 8;\n    if (positiveSentimentHits > 0) commercial += 20;\n    if (f.products.length > 0) commercial += 15;\n    commercial = Math.min(100, Math.round(commercial * 10) / 10);\n\n    let followersTotal = 0;\n    let platformsActive = 0;\n    let engagementBonus = 0;\n\n    for (const s of f.socialSignals) {\n      followersTotal += (s.followers || 0);\n      if (s.platform) platformsActive += 1;\n      if ((s.engagement_signals || []).length > 0) engagementBonus = 20;\n    }\n\n    social += Math.min(followersTotal / 10000, 30);\n    social += Math.min(platformsActive * 10, 30);\n    social += engagementBonus;\n    social += Math.min((f.actions || []).length * 4, 20);\n    social = Math.min(100, Math.round(social * 10) / 10);\n\n    const overall = Math.round((commercial * 0.6 + social * 0.4) * 10) / 10;\n\n    factories.push({\n      factory_name: f.factory_name,\n      _all_fresh: allFresh,\n      commercial_score: commercial,\n      social_score: social,\n      overall_score: overall,\n      products: f.products,\n      marketIntel: f.marketIntel,\n      socialSignals: f.socialSignals,\n      actions: f.actions\n    });\n  }\n\n  const byCommercial = factories.slice().sort(function(a, b) { return b.commercial_score - a.commercial_score; });\n  const mostSold = byCommercial.map(function(f, idx) { return Object.assign({}, f, { commercial_rank: idx + 1 }); });\n\n  const bySocial = factories.slice().sort(function(a, b) { return b.social_score - a.social_score; });\n  const mostInfluential = bySocial.map(function(f, idx) { return Object.assign({}, f, { social_rank: idx + 1 }); });\n\n  factories.sort(function(a, b) { return b.overall_score - a.overall_score; });\n\n  return [{ json: { factories: factories, most_sold: mostSold, most_influential: mostInfluential } }];\n} catch (e) {\n  return [{ json: { factories: [], most_sold: [], most_influential: [], score_error: e.message } }];\n}"
