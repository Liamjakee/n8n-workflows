        "jsCode": "try {\n  const f = $input.item.json;\n  const name = f.factory_name;\n\n  // Guard: if factory_name is missing the list node errored — skip gracefully\n  if (!name || name === 'DESCONOCIDO') {\n    return [{ json: { research_task_error: 'factory_name ausente o desconocido', factory_name: 'DESCONOCIDO' } }];\n  }\n\n  const slug = f.factory_slug || name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');\n\n  const igUrl = (f.instagram_url && f.instagram_url.startsWith('http'))\n    ? f.instagram_url\n    : ('https://www.instagram.com/' + slug);\n\n  const ttUrl = (f.tiktok_url && f.tiktok_url.startsWith('http'))\n    ? f.tiktok_url\n    : ('https://www.tiktok.com/@' + slug);\n\n  const sources = [\n    { source_type: 'bestsellers',     label: 'Colecciones / Más vendidos',     url: f.bestsellers_url },\n    { source_type: 'google_trending', label: 'Google - novedades y tendencias', url: 'https://www.google.it/search?q=' + encodeURIComponent(name + ' nuovi modelli divani 2026') },\n    { source_type: 'instagram',       label: 'Instagram perfil',                url: igUrl },\n    { source_type: 'tiktok',          label: 'TikTok perfil',                   url: ttUrl },\n    { source_type: 'google_reviews',  label: 'Google - reseñas',                url: 'https://www.google.it/search?q=' + encodeURIComponent(name + ' recensioni divani opinioni') }\n  ].filter(function(s) { return s.url && s.url.length > 10; });\n\n  return sources.map(function(s) {\n    return {\n      json: {\n        run_date: f.run_date,\n        factory_name: name,\n        factory_slug: slug,\n        trigger_type: f.trigger_type,\n        chat_id: f.chat_id,\n        from_user: f.from_user,\n        source_type: s.source_type,\n        source_label: s.label,\n        url: s.url\n      }\n    };\n  });\n} catch (e) {\n  return [{ json: { research_task_error: e.message, factory_name: $input.item.json.factory_name || 'DESCONOCIDO' } }];\n}"
