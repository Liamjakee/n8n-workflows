    {
      "id": "filter-relevance",
      "name": "Filtrar por Relevancia Sofas",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1500, 550],
      "parameters": {
        "jsCode": "try {\n  // All 11 target brands — any mention passes the filter regardless of context\n  const brands = [\n    'natuzzi', 'max divani', 'estro milano', 'innova imbottiti',\n    'franco ferri', 'nicoletti', 'calia italia', 'ego italiano',\n    'gorini', 'doimo salotti', 'diva divani'\n  ];\n\n  // General sofa/upholstery trade terms\n  const sofaTerms = [\n    'sofa', 'divano', 'divani', 'sofa', 'canape',\n    'upholstery', 'imbottito', 'imbottiti', 'poltrona',\n    'seduta imbottita', 'collezione divani', 'salone del mobile',\n    'isaloni', 'arredamento imbottito', 'mobili imbottiti'\n  ];\n\n  const allKeywords = [...brands, ...sofaTerms];\n\n  const items = $input.all();\n  const seen = new Set();\n  const matched = [];\n\n  for (const item of items) {\n    const j = item.json;\n    const link = (j.link || j.url || '').trim();\n\n    // Deduplicate by URL\n    if (link && seen.has(link)) continue;\n    if (link) seen.add(link);\n\n    const text = [\n      j.title,\n      j.contentSnippet,\n      j.content,\n      j.description,\n      j.summary\n    ].filter(Boolean).join(' ').toLowerCase();\n\n    const matchedKw = allKeywords.find(kw => text.includes(kw));\n    if (matchedKw) {\n      matched.push({\n        title: j.title || 'Sans titre',\n        link: link,\n        pubDate: j.pubDate || j.isoDate || '',\n        snippet: (j.contentSnippet || j.description || j.summary || '').slice(0, 400),\n        source: j.feedTitle || '',\n        matched_keyword: matchedKw\n      });\n    }\n  }\n\n  return [{\n    json: {\n      articles: matched,\n      articles_count: matched.length,\n      run_date: new Date().toISOString().split('T')[0]\n    }\n  }];\n} catch (e) {\n  return [{ json: { articles: [], articles_count: 0, filter_error: e.message, run_date: new Date().toISOString().split('T')[0] } }];\n}"
      }
    },
