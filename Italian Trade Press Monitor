      "id": "format-bulletin",
      "name": "Formatear Bulletin Telegram",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2700, 350],
      "parameters": {
        "jsCode": "try {\n  const item = $input.item.json;\n\n  // Rate limit handling — CLAUDE.md pattern: catch 429, surface clearly\n  if (item.error) {\n    const errMsg = item.error?.message || JSON.stringify(item.error);\n    const is429 = errMsg.includes('429') || errMsg.toLowerCase().includes('rate_limit') || errMsg.toLowerCase().includes('rate limit');\n    if (is429) {\n      // Read retry_after if available (Groq returns it in the error body)\n      const retryAfter = item.error?.headers?.['retry-after'] || '60';\n      const msg = `Groq rate limit 429 \\u2014 retry_after: ${retryAfter}s. Bulletin sera genere au prochain cycle.`;\n      return [{ json: { ...item, telegram_text: msg, telegram_parse_mode: 'HTML' } }];\n    }\n    return [{ json: { ...item, telegram_text: `Erreur Groq: ${errMsg.slice(0, 200)}`, telegram_parse_mode: 'HTML' } }];\n  }\n\n  const groqText = item.choices?.[0]?.message?.content || '';\n  if (!groqText) {\n    return [{ json: { ...item, telegram_text: 'Groq a retourne une reponse vide.', telegram_parse_mode: 'HTML' } }];\n  }\n\n  const runDate = item.run_date || new Date().toISOString().split('T')[0];\n  const articlesCount = item.articles_count || 0;\n\n  // Telegram MarkdownV2: escape all reserved characters\n  const escMd = (s) => String(s).replace(/([_*[\\]()~`>#+\\-=|{}.!\\\\])/g, '\\\\$1');\n\n  const header = `\\uD83D\\uDECB *Veille Presse Italienne \\u2014 ${escMd(runDate)}*\\n_${articlesCount} article\\(s\\) filtr\\u00e9\\(s\\)_\\n\\n`;\n  const body = escMd(groqText);\n  const footer = `\\n\\n_Spy de muebles \\u00b7 @Spymuebles\\_bot_`;\n\n  return [{ json: { ...item, telegram_text: header + body + footer, telegram_parse_mode: 'MarkdownV2' } }];\n} catch (e) {\n  return [{ json: { ...$input.item.json, format_error: e.message, telegram_text: `Erreur de formatage: ${e.message}`, telegram_parse_mode: 'HTML' } }];\n}"
      }
    },
