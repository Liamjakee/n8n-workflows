    {
      "id": "build-groq-prompt",
      "name": "Construir Prompt Groq",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2100, 350],
      "parameters": {
        "jsCode": "try {\n  const data = $input.item.json;\n  const articles = data.articles || [];\n  const runDate = data.run_date || new Date().toISOString().split('T')[0];\n\n  const articlesList = articles.map((a, i) =>\n    `${i + 1}. ${a.title}\\nSource: ${a.source || 'inconnue'} | Date: ${a.pubDate || 'N/A'} | Mot-cle: ${a.matched_keyword}\\n${a.snippet}`\n  ).join('\\n\\n');\n\n  const systemPrompt = 'Tu es un analyste specialise dans l\\'industrie du meuble italien, en particulier les canapes et sofas. ' +\n    'Marques cibles: Natuzzi, Max Divani, Estro Milano, Innova Imbottiti, Franco Ferri, Nicoletti, Calia Italia, ' +\n    'Ego Italiano, Gorini, Doimo Salotti, Diva Divani. ' +\n    'Tu rediges des bulletins de veille quotidiens en francais: concis, structures, professionnels. ' +\n    'Format attendu: titre accrocheur, faits cles groupes par marque ou theme, tendances du jour. Maximum 400 mots.';\n\n  const userPrompt = `Date du bulletin: ${runDate}\\nNombre d'articles filtres: ${articles.length}\\n\\n${articlesList}\\n\\nRedige le bulletin de veille en francais.`;\n\n  const groqPayload = {\n    model: 'llama-3.3-70b-versatile',\n    messages: [\n      { role: 'system', content: systemPrompt },\n      { role: 'user', content: userPrompt }\n    ],\n    max_tokens: 1500,\n    temperature: 0.3\n  };\n\n  return [{ json: { ...data, groq_payload: groqPayload, run_date: runDate } }];\n} catch (e) {\n  return [{ json: { ...$input.item.json, prompt_build_error: e.message } }];\n}"
      }
    },
